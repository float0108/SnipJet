{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["*"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-hide",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-focus",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "core:webview:default",
    "core:webview:allow-internal-toggle-devtools",
    "core:webview:allow-create-webview-window",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:window:allow-start-dragging",
    "core:window:allow-show",
    "core:window:allow-is-visible",
    "core:window:allow-set-position",
    "core:window:allow-cursor-position",
    "core:window:allow-outer-size",
    "core:window:allow-set-focusable",
    "core:window:allow-monitor-from-point",
    "core:window:allow-primary-monitor",
    "core:window:allow-available-monitors",
    "fs:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister-all",

    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{"path": "$APPCONFIG/*"}]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{"path": "$APPCONFIG/*"}]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{"path": "$APPCONFIG"}, {"path": "$APPCONFIG/*"}]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{"path": "$APPCONFIG"}, {"path": "$APPCONFIG/*"}]
    },
    "allow-print-message",
    "allow-update-window-pin-state",
    "allow-clipboard-operations",
    "allow-register-global-shortcut",
    "allow-unregister-global-shortcut",
    "allow-text-expand-operations",
    "allow-image-operations"
  ]
}
